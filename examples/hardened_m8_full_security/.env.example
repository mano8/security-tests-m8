# security-tests-m8 live configuration for:
# /workspace/fa-auth-m8/examples/docker_compose/hardened_m8

LIVE_TEST_AUTH_BASE=http://localhost:9000/user
LIVE_TEST_SVC_BASE=http://localhost:9000/fastapi
LIVE_TEST_SVC_BASES={"fastapi":"http://localhost:9000/fastapi"}
LIVE_TEST_DEFAULT_SVC=fastapi

# Dedicated test-only superuser. Do not use FIRST_SUPERUSER from auth.env.
LIVE_TEST_ADMIN_EMAIL=changethis
LIVE_TEST_ADMIN_PASSWORD=changethis

# Optional opt-in checks. Uncomment and set to the real values from auth.env/api.env.
# LIVE_TEST_PRIVATE_API_SECRET=changethis
# Per-consumer id (X-Internal-Client) for fa-auth-m8 >= 1.0.0 issuers. Set it with
# LIVE_TEST_PRIVATE_API_SECRET to authenticate private-API probes under the
# per-consumer model and enable the F06 legacy-detection check. Unset = legacy stack.
# LIVE_TEST_PRIVATE_API_CLIENT_ID=media-service
# Dedicated credential that unlocks the deep /health detail body (token mode,
# Redis/DB) for stack detection and token-mode/disclosure suites. fa-auth-m8
# >= 1.0.0 gates that detail on HEALTH_DETAIL_CREDENTIAL (X-Internal-Token),
# decoupled from PRIVATE_API_SECRET. Set to the stack's HEALTH_DETAIL_CREDENTIAL.
# LIVE_TEST_HEALTH_DETAIL_CREDENTIAL=changethis
# LIVE_TEST_REFRESH_SECRET_KEY=changethis

LIVE_TEST_TIMEOUT=10
LIVE_TEST_FAIL_FAST_PREFLIGHT=true
LIVE_TEST_FORBID_BOOTSTRAP_SUPERUSER=true
LIVE_TEST_PROTECTED_ENDPOINTS={"fastapi":["/category/","/dashboard/users/activity/"]}
LIVE_TEST_PUBLIC_BASE=https://localhost:4430
LIVE_TEST_PUBLIC_TLS_VERIFY=false
LIVE_TEST_REPO_ROOT=/workspace/fa-auth-m8/examples/docker_compose/hardened_m8
LIVE_TEST_DEPLOYMENT_ROOT=/workspace/fa-auth-m8/examples/docker_compose/hardened_m8
HARDENED_M8_STACK_ROOT=/workspace/fa-auth-m8/examples/docker_compose/hardened_m8
